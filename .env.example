# --- Slack ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# --- GitHub App ---
GITHUB_APP_ID=...
# base64-encoded PEM private key (base64 -i private-key.pem | pbcopy)
GITHUB_APP_PRIVATE_KEY=...
GITHUB_WEBHOOK_SECRET=...
GITHUB_INSTALLATION_ID=...
GITHUB_ORG=your-org

# --- Infra ---
# Any Postgres works and also backs the job queue (pg-boss) — no Redis needed.
DATABASE_URL=postgres://user:pass@host:5432/postgres
# Single shared channel that holds one threaded message per PR.
PR_CHANNEL_NAME=pr-approve
PORT=3000
TZ=UTC
LOG_LEVEL=info

# --- GitHub OAuth (verified per-user identity; reviews post as the real user) ---
# Required for /pullpod connect. Leave blank to disable OAuth-backed features.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# 32-byte key (hex or base64) that encrypts stored user tokens at rest.
TOKEN_ENC_KEY=
# Public base URL of this service (OAuth callback), e.g. https://your-service.example.com
PUBLIC_URL=

# --- Optional ---
# Per-repo merge allowlist as JSON, keyed by short repo name:
# {"web":["alice","bob"]} = only alice/bob may merge PRs in the `web` repo.
MERGE_RESTRICTIONS=
SENTRY_DSN=
OPS_CHANNEL_ID=
